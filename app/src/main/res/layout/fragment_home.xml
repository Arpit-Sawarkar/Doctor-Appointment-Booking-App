<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    android:overScrollMode="never"
    android:background="@color/blue">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_marginBottom="10dp"
        android:background="#FFFFFF">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:orientation="vertical"
            android:paddingTop="14dp"
            android:background="@drawable/bg_top_curve">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" Life Care +"
                android:layout_marginStart="20dp"
                android:layout_marginBottom="6dp"
                android:textColor="@android:color/white"
                android:textSize="23sp"
                android:textStyle="bold" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_searchcolour"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginStart="15dp"
                android:layout_marginEnd="15dp"
                android:gravity="center_vertical"
                android:elevation="5dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="#7A7A7A" />
                <AutoCompleteTextView
                    android:id="@+id/atvSpecialty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:hint="Search doctors, specialties"
                    android:background="@null"
                    android:textSize="15sp"
                    android:textColor="#000000"
                    android:textColorHint="#7A7A7A"
                    android:singleLine="true"
                    android:imeOptions="actionSearch"/>
            </LinearLayout>
        </LinearLayout>
        <ImageView
            android:id="@+id/imgmain"
            android:layout_width="385dp"
            android:layout_marginTop="5dp"
            android:layout_height="180dp"
            android:scaleType="fitCenter"
            android:src="@drawable/main_photo" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="   Our Speciality"
            android:textStyle="bold"
            android:textSize="20sp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:textColor="#000000" />
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:columnCount="2"
            android:padding="12dp"
            android:layout_marginBottom="0dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="12dp"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:id="@+id/imgGeneral"
                    android:src="@drawable/general"
                    android:scaleType="fitCenter"/>
                <TextView
                    android:layout_marginTop="8dp"
                    android:text="General Physician"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#4A4A4A"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="12dp"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_marginTop="10dp"
                    android:id="@+id/dentist"
                    android:src="@drawable/dentist"
                    android:scaleType="fitCenter"/>
                <TextView
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dentist"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#4A4A4A"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="12dp"
                android:orientation="vertical"
                android:gravity="center">
            <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:id="@+id/imgCardiologist"
                    android:src="@drawable/cardiologist"
                    android:scaleType="fitCenter"/>
                <TextView
                    android:layout_marginTop="8dp"
                    android:text="Cardiologist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#4A4A4A"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="12dp"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="95dp"
                    android:layout_height="95dp"
                    android:id="@+id/gynaecologist"
                    android:src="@drawable/gynocologist"
                    android:scaleType="fitCenter"/>
                <TextView
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gynaecologist"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#4A4A4A"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="12dp"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:id="@+id/eye"
                    android:src="@drawable/eye"
                    android:scaleType="fitCenter"/>
                <TextView
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Eye Surgeon"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#4A4A4A"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="12dp"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="95dp"
                    android:layout_height="95dp"
                    android:id="@+id/imgENT"
                    android:src="@drawable/ent"
                    android:scaleType="fitCenter"/>
                <TextView
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ENT"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#4A4A4A"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="12dp"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:id="@+id/imgDermatologist"
                    android:src="@drawable/dermatologist"
                    android:scaleType="fitCenter"/>
                <TextView
                    android:layout_marginTop="8dp"
                    android:text="Dermatologist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#4A4A4A"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="12dp"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:id="@+id/imgOrthopadic"
                    android:src="@drawable/orthopadic"
                    android:scaleType="fitCenter"/>
                <TextView
                    android:layout_marginTop="8dp"
                    android:text="Orthopedic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#4A4A4A"/>
            </LinearLayout>
        </GridLayout>
    </LinearLayout>
</ScrollView>

