<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">
    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal">
        <ImageView
            android:id="@+id/imgDoctor"
            android:layout_width="253dp"
            android:layout_height="246dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_searchcolour"
            android:clipToOutline="true"
            android:outlineProvider="background"
            android:padding="4dp"
            android:scaleType="centerCrop" />
        <TextView
            android:id="@+id/tvDoctorName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"/>
        <TextView
            android:id="@+id/tvSpecialization"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="19sp"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp"/>
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:paddingBottom="7dp"
            android:background="@android:color/darker_gray"
            android:layout_marginVertical="8dp"/>
        <TextView
            android:id="@+id/tvQualification"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:paddingBottom="5dp"
            android:layout_marginTop="12dp"
            android:textColor="@color/black"
            android:layout_marginVertical="2dp"/>
        <TextView
            android:id="@+id/tvExperience"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="5dp"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:layout_marginVertical="2dp"/>
        <TextView
            android:id="@+id/tvAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:paddingBottom="5dp"
            android:textColor="@color/black"
            android:layout_marginVertical="2dp"/>
        <TextView
            android:id="@+id/tvFees"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:paddingBottom="5dp"
            android:textColor="@color/black"
            android:layout_marginVertical="2dp"/>
        <LinearLayout
            android:id="@+id/layoutVerified"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="4dp">
            <TextView
                android:id="@+id/tvVerified"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Verified  "
                android:textSize="17dp"
                android:textColor="@color/black"
                android:visibility="visible"
                android:textStyle="bold"/>
            <ImageView
                android:id="@+id/imgVerified"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/check"
                android:visibility="visible"
                android:layout_marginEnd="6dp"/>
        </LinearLayout>
        <TextView
            android:id="@+id/tvContactNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:layout_marginVertical="2dp"/>
        <TextView
            android:id="@+id/tvService"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="About Doctor:"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:layout_marginTop="13dp"/>
        <TextView
            android:id="@+id/tvServiceDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:layout_marginTop="4dp"
            android:lineSpacingExtra="2dp"/>
        <Button
            android:id="@+id/btnBookConsultancy"
            android:layout_width="245dp"
            android:layout_height="49dp"
            android:layout_marginTop="19dp"
            android:backgroundTint="@color/blue"
            android:text="Book Appointment"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="15dp" />
    </LinearLayout>
</ScrollView>
